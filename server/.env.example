# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lia_dashboard?schema=public"

# JWT
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# AI Keys (central fallback)
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
