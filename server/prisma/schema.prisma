// Prisma Schema for LIA Dashboard
// PostgreSQL database with multi-tenant organization support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================
// ORGANIZATIONS (Multi-tenant root)
// ==============================
model Organization {
  id           String  @id @default(uuid())
  slug         String  @unique // URL-friendly: "innovation-institute"
  name         String
  type         OrgType @default(infoproductor)
  description  String  @default("")
  tagline      String?
  website      String?
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")
  whatsapp     String?

  // Extended fields (type-specific)
  accreditations String? // universidad
  specialty      String? // instituto
  personalBrand  String? @map("personal_brand") // infoproductor
  niche          String? // infoproductor
  targetAudience String? @map("target_audience")
  history        String?

  // JSONB fields for complex nested data
  branding       Json     @default("{}") // BrandingConfig: { colors, typography, voice, visualIdentity }
  socialMedia    Json?    @map("social_media") // { instagram, facebook, linkedin, tiktok, youtube, website }
  operatingHours Json?    @map("operating_hours") // [{ days, hours }]
  locations      Json     @default("[]") // [{ id, name, address, phone, schedule }]
  paymentMethods Json     @default("[]") @map("payment_methods") // [{ type, name, details, currency }]
  certificates   String[] @default([]) // Acreditaciones, certificaciones, licencias
  modalities     String[] @default([]) // ["Online", "Presencial", "Híbrido"]
  courseCategories String[] @map("course_categories")

  onboardingComplete Boolean @default(false) @map("onboarding_complete")

  // Relations
  users            User[]
  courses          Course[]
  programs         Program[]
  webinars         Webinar[]
  talleres         Taller[]
  subscriptions    Subscription[]
  asesorias        Asesoria[]
  applications     Application[]
  teams            Team[]
  agents           AiAgent[]
  apiKeys          ApiKey[]
  generatedContent GeneratedContent[]
  contacts         Contact[]
  funnels          Funnel[]
  extractionFields ExtractionField[]
  filterQuestions  FilterQuestion[]
  ghlConnection    GhlConnection?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organizations")
}

enum OrgType {
  universidad
  instituto
  infoproductor
}

// ==============================
// USERS (Auth + Roles)
// ==============================
model User {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         UserRole  @default(editor)
  phone        String?   @map("phone")
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teamMember TeamMember?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("users")
}

enum UserRole {
  admin
  editor
  viewer
}

// ==============================
// COURSES (Cursos Libres)
// ==============================
model Course {
  id                String    @id @default(uuid())
  orgId             String    @map("org_id")
  code              String    @unique // CRS-AI2024-001
  title             String
  subtitle          String?
  description       String    @default("")
  objectives        String[]  @default([])
  targetAudience    String    @default("") @map("target_audience")
  modality          Modality  @default(online)
  startDate         DateTime? @map("start_date")
  endDate           DateTime? @map("end_date")
  duration          String    @default("")
  totalHours        Int?      @map("total_hours")
  schedule          String?
  instructor        String    @default("")
  instructorBio     String?   @map("instructor_bio")
  price             Decimal   @default(0)
  currency          String    @default("USD")
  earlyBirdPrice    Decimal?  @map("early_bird_price")
  earlyBirdDeadline DateTime? @map("early_bird_deadline")
  promotions        String?
  requirements      String[]  @default([])
  contactInfo       Json?     @map("contact_info") // { name, email, phone }

  // Commercial fields
  benefits             String[]   @default([])
  painPoints           String[]   @default([]) @map("pain_points")
  guarantee            String?
  socialProof          String[]   @default([]) @map("social_proof")
  bonuses              String[]   @default([])
  maxStudents          Int?       @map("max_students")
  prerequisites        String?
  certification        String?
  registrationLink     String?    @map("registration_link")
  paymentMethods       String[]   @default([]) @map("payment_methods")
  location             String?    @default("Virtual")
  category             String     @default("")
  tags                 String[]   @default([])
  tools                String[]   @default([])
  status               ItemStatus @default(borrador)
  aiSummary            String?    @map("ai_summary")
  // New commercial fields for sales agents
  callToAction         String?    @map("call_to_action")
  idealStudentProfile  String?    @map("ideal_student_profile")
  competitiveAdvantage String?    @map("competitive_advantage")
  urgencyTriggers      String[]   @default([]) @map("urgency_triggers")
  objectionHandlers    Json       @default("[]") @map("objection_handlers") // [{objection, response}]
  successStories       Json       @default("[]") @map("success_stories") // [{name, role, quote, result}]

  // Relations
  org              Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teamId           String?                @map("team_id")
  team             Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  syllabusModules  SyllabusModule[]
  attachments      Attachment[]
  faqs             Faq[]
  generatedContent GeneratedContent[]
  agentCourses     AgentCourse[]
  filterQuestions  FilterQuestion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([orgId, status])
  @@index([code])
  @@map("courses")
}

model SyllabusModule {
  id          String   @id @default(uuid())
  courseId    String   @map("course_id")
  week        Int?
  title       String
  description String   @default("")
  topics      String[] @default([])
  hours       Int      @default(0)
  sortOrder   Int      @default(0) @map("sort_order")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("syllabus_modules")
}

// ==============================
// PROGRAMS (Diplomados, Maestrías)
// ==============================
model Program {
  id             String    @id @default(uuid())
  orgId          String    @map("org_id")
  code           String    @unique // PRG-MBA2024-001
  title          String
  subtitle       String?
  description    String    @default("")
  objectives     String[]  @default([])
  targetAudience String    @default("") @map("target_audience")
  modality       Modality  @default(online)
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  totalDuration  String    @default("") @map("total_duration")
  totalHours     Int       @default(0) @map("total_hours")
  coordinator    String?
  schedule       String?
  price          Decimal   @default(0)
  currency       String    @default("USD")
  earlyBirdPrice Decimal?  @map("early_bird_price")
  promotions     String?
  requirements   String[]  @default([])
  contactInfo    Json?     @map("contact_info")

  // Commercial fields
  benefits             String[]   @default([])
  painPoints           String[]   @default([]) @map("pain_points")
  guarantee            String?
  socialProof          String[]   @default([]) @map("social_proof")
  bonuses              String[]   @default([])
  maxStudents          Int?       @map("max_students")
  prerequisites        String?
  certification        String     @default("")
  certifyingEntity     String?    @map("certifying_entity")
  registrationLink     String?    @map("registration_link")
  paymentMethods       String[]   @default([]) @map("payment_methods")
  whatsappGroup        String?    @map("whatsapp_group")
  includesProject      Boolean    @default(false) @map("includes_project")
  location             String?    @default("Virtual")
  category             String     @default("")
  tags                 String[]   @default([])
  tools                String[]   @default([])
  status               ItemStatus @default(borrador)
  aiSummary            String?    @map("ai_summary")
  // New commercial fields for sales agents
  callToAction         String?    @map("call_to_action")
  idealStudentProfile  String?    @map("ideal_student_profile")
  competitiveAdvantage String?    @map("competitive_advantage")
  urgencyTriggers      String[]   @default([]) @map("urgency_triggers")
  objectionHandlers    Json       @default("[]") @map("objection_handlers") // [{objection, response}]
  successStories       Json       @default("[]") @map("success_stories") // [{name, role, quote, result}]

  // Relations
  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teamId           String?            @map("team_id")
  team             Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  programCourses   ProgramCourse[]
  attachments      Attachment[]
  faqs             Faq[]
  generatedContent GeneratedContent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([orgId, status])
  @@map("programs")
}

model ProgramCourse {
  id          String   @id @default(uuid())
  programId   String   @map("program_id")
  sortOrder   Int      @default(0) @map("sort_order")
  title       String
  description String?
  hours       Int      @default(0)
  instructor  String?
  topics      String[] @default([])

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@map("program_courses")
}

// ==============================
// WEBINARS
// ==============================
model Webinar {
  id             String    @id @default(uuid())
  orgId          String    @map("org_id")
  code           String    @unique // WBN-MKT2024-001
  title          String
  subtitle       String?
  description    String    @default("")
  webinarFormat  String    @default("webinar") @map("webinar_format") // webinar, masterclass, charla
  speaker        String    @default("")
  speakerBio     String?   @map("speaker_bio")
  speakerTitle   String?   @map("speaker_title")
  eventDate      DateTime? @map("event_date")
  eventTime      String?   @map("event_time")
  duration       String    @default("")
  modality       Modality  @default(online)
  platform       String?
  price          Decimal   @default(0)
  currency       String    @default("USD")
  maxAttendees   Int?      @map("max_attendees")
  topics         String[]  @default([])
  keyTopics      String[]  @default([]) @map("key_topics")
  targetAudience String    @default("") @map("target_audience")
  callToAction   String?   @map("call_to_action")
  requirements   String[]  @default([])
  contactInfo    Json?     @map("contact_info")

  // Commercial fields
  benefits             String[]   @default([])
  painPoints           String[]   @default([]) @map("pain_points")
  guarantee            String?
  socialProof          String[]   @default([]) @map("social_proof")
  bonuses              String[]   @default([])
  registrationLink     String?    @map("registration_link")
  paymentMethods       String[]   @default([]) @map("payment_methods")
  promotions           String?
  location             String?    @default("Virtual")
  category             String     @default("")
  tags                 String[]   @default([])
  tools                String[]   @default([])
  status               ItemStatus @default(borrador)
  aiSummary            String?    @map("ai_summary")
  // New commercial fields for sales agents
  idealStudentProfile  String?    @map("ideal_student_profile")
  competitiveAdvantage String?    @map("competitive_advantage")
  urgencyTriggers      String[]   @default([]) @map("urgency_triggers")
  objectionHandlers    Json       @default("[]") @map("objection_handlers") // [{objection, response}]
  successStories       Json       @default("[]") @map("success_stories") // [{name, role, quote, result}]

  // Relations
  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teamId           String?            @map("team_id")
  team             Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  attachments      Attachment[]
  faqs             Faq[]
  generatedContent GeneratedContent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([orgId, status])
  @@map("webinars")
}

// ==============================
// TALLERES (Workshops)
// ==============================
model Taller {
  id             String    @id @default(uuid())
  orgId          String    @map("org_id")
  code           String    @unique // TLR-IA2024-001
  title          String
  subtitle       String?
  description    String    @default("")
  objectives     String[]  @default([])
  targetAudience String    @default("") @map("target_audience")
  modality       Modality  @default(presencial)
  eventDate      DateTime? @map("event_date")
  eventTime      String?   @map("event_time")
  duration       String    @default("")
  totalHours     Int?      @map("total_hours")
  schedule       String?

  // Instructor / Facilitator
  instructor    String  @default("")
  instructorBio String? @map("instructor_bio")

  // Venue / Location
  venue         String? // Nombre del local/sala
  venueAddress  String? @map("venue_address")
  venueCapacity Int?    @map("venue_capacity")
  location      String? @default("Presencial")

  // Pricing & Registration
  price             Decimal   @default(0)
  currency          String    @default("USD")
  earlyBirdPrice    Decimal?  @map("early_bird_price")
  earlyBirdDeadline DateTime? @map("early_bird_deadline")
  promotions        String?
  registrationLink  String?   @map("registration_link")
  paymentMethods    String[]  @default([]) @map("payment_methods")

  // Capacity
  maxParticipants Int?    @map("max_participants")
  availableSpots  Int?    @map("available_spots")
  waitlistEnabled Boolean @default(false) @map("waitlist_enabled")

  // Content
  materials     String[] @default([]) // Materiales incluidos
  deliverables  String[] @default([]) // Lo que se llevan
  certification String?
  requirements  String[] @default([])
  contactInfo   Json?    @map("contact_info")

  // Commercial fields
  benefits             String[]   @default([])
  painPoints           String[]   @default([]) @map("pain_points")
  guarantee            String?
  socialProof          String[]   @default([]) @map("social_proof")
  bonuses              String[]   @default([])
  tools                String[]   @default([])
  category             String     @default("")
  tags                 String[]   @default([])
  status               ItemStatus @default(borrador)
  aiSummary            String?    @map("ai_summary")
  // New commercial fields for sales agents
  callToAction         String?    @map("call_to_action")
  idealStudentProfile  String?    @map("ideal_student_profile")
  competitiveAdvantage String?    @map("competitive_advantage")
  urgencyTriggers      String[]   @default([]) @map("urgency_triggers")
  objectionHandlers    Json       @default("[]") @map("objection_handlers") // [{objection, response}]
  successStories       Json       @default("[]") @map("success_stories") // [{name, role, quote, result}]

  // Relations
  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teamId           String?            @map("team_id")
  team             Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  attachments      Attachment[]
  faqs             Faq[]
  generatedContent GeneratedContent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([orgId, status])
  @@map("talleres")
}

// ==============================
// SUBSCRIPTIONS (Suscripciones)
// ==============================
model Subscription {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  code           String   @unique
  title          String
  subtitle       String?
  description    String   @default("")
  benefits       String[] @default([])
  features       String[] @default([])
  price          Decimal  @default(0)
  currency       String   @default("USD")
  period         String   @default("mensual") // mensual, anual, trimestral
  maxUsers       Int?     @map("max_users")
  promotions     String?
  targetAudience String   @default("") @map("target_audience")
  objectives     String[] @default([])
  requirements   String[] @default([])
  contactInfo    Json?    @map("contact_info")

  // Advisory / Access
  advisoryHours    Int?     @map("advisory_hours") // horas de asesoría incluidas
  whatsappGroup    String?  @map("whatsapp_group")
  communityAccess  String?  @map("community_access") // link o descripción del acceso
  registrationLink String?  @map("registration_link")
  paymentMethods   String[] @default([]) @map("payment_methods")

  // Commercial fields
  painPoints           String[]   @default([]) @map("pain_points")
  guarantee            String?
  socialProof          String[]   @default([]) @map("social_proof")
  bonuses              String[]   @default([])
  tools                String[]   @default([])
  location             String?    @default("Virtual")
  category             String     @default("")
  tags                 String[]   @default([])
  status               ItemStatus @default(borrador)
  aiSummary            String?    @map("ai_summary")
  // New commercial fields for sales agents
  callToAction         String?    @map("call_to_action")
  idealStudentProfile  String?    @map("ideal_student_profile")
  competitiveAdvantage String?    @map("competitive_advantage")
  urgencyTriggers      String[]   @default([]) @map("urgency_triggers")
  objectionHandlers    Json       @default("[]") @map("objection_handlers") // [{objection, response}]
  successStories       Json       @default("[]") @map("success_stories") // [{name, role, quote, result}]

  // Relations
  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  attachments      Attachment[]
  faqs             Faq[]
  generatedContent GeneratedContent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("subscriptions")
}

// ==============================
// ASESORÍAS (Consulting/Advisory)
// ==============================
model Asesoria {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  code           String   @unique // ASE-IA2024-001
  title          String
  subtitle       String?
  description    String   @default("")
  objectives     String[] @default([])
  targetAudience String   @default("") @map("target_audience")
  modality       Modality @default(online)

  // Pricing
  pricePerHour   Decimal  @default(0) @map("price_per_hour")
  currency       String   @default("USD")
  minimumHours   Int      @default(1) @map("minimum_hours")
  packageHours   Int?     @map("package_hours") // paquete de horas con descuento
  packagePrice   Decimal? @map("package_price")
  promotions     String?
  paymentMethods String[] @default([]) @map("payment_methods")

  // Advisor
  advisor      String   @default("")
  advisorBio   String?  @map("advisor_bio")
  advisorTitle String?  @map("advisor_title")
  specialties  String[] @default([])

  // Scheduling
  bookingLink       String? @map("booking_link")
  registrationLink  String? @map("registration_link")
  minAdvanceBooking String? @map("min_advance_booking") // "1 hora", "24 horas"
  availableSchedule String? @map("available_schedule") // Horarios disponibles
  sessionDuration   String? @map("session_duration") // Duración típica de sesión

  // Content
  topicsCovered    String[] @default([]) @map("topics_covered")
  deliverables     String[] @default([]) // Entregables por sesión
  requirements     String[] @default([])
  contactInfo      Json?    @map("contact_info")
  needsDescription Boolean  @default(true) @map("needs_description") // cliente debe describir necesidad

  // Commercial fields
  benefits             String[]   @default([])
  painPoints           String[]   @default([]) @map("pain_points")
  guarantee            String?
  socialProof          String[]   @default([]) @map("social_proof")
  bonuses              String[]   @default([])
  tools                String[]   @default([])
  location             String?    @default("Virtual")
  category             String     @default("")
  tags                 String[]   @default([])
  status               ItemStatus @default(borrador)
  aiSummary            String?    @map("ai_summary")
  // New commercial fields for sales agents
  callToAction         String?    @map("call_to_action")
  idealStudentProfile  String?    @map("ideal_student_profile")
  competitiveAdvantage String?    @map("competitive_advantage")
  urgencyTriggers      String[]   @default([]) @map("urgency_triggers")
  objectionHandlers    Json       @default("[]") @map("objection_handlers") // [{objection, response}]
  successStories       Json       @default("[]") @map("success_stories") // [{name, role, quote, result}]

  // Relations
  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teamId           String?            @map("team_id")
  team             Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  attachments      Attachment[]
  faqs             Faq[]
  generatedContent GeneratedContent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([orgId, status])
  @@map("asesorias")
}

// ==============================
// APPLICATIONS (Postulaciones)
// ==============================
model Application {
  id             String    @id @default(uuid())
  orgId          String    @map("org_id")
  code           String    @unique
  title          String
  subtitle       String?
  description    String    @default("")
  price          Decimal   @default(0) // application fee
  currency       String    @default("USD")
  requirements   String[]  @default([])
  deadline       DateTime?
  availableSlots Int?      @map("available_slots")
  modality       Modality  @default(online)
  startDate      DateTime? @map("start_date")
  duration       String?
  promotions     String?
  targetAudience String    @default("") @map("target_audience")
  objectives     String[]  @default([])
  contactInfo    Json?     @map("contact_info")

  // Application process
  examRequired      Boolean  @default(false) @map("exam_required")
  examDescription   String?  @map("exam_description")
  applicationFee    Decimal? @map("application_fee")
  steps             String[] @default([]) // Pasos del proceso
  documentsNeeded   String[] @default([]) @map("documents_needed")
  selectionCriteria String[] @default([]) @map("selection_criteria")
  registrationLink  String?  @map("registration_link")
  paymentMethods    String[] @default([]) @map("payment_methods")

  // Commercial fields
  benefits             String[]   @default([])
  painPoints           String[]   @default([]) @map("pain_points")
  guarantee            String?
  socialProof          String[]   @default([]) @map("social_proof")
  bonuses              String[]   @default([])
  tools                String[]   @default([])
  location             String?    @default("Virtual")
  category             String     @default("")
  tags                 String[]   @default([])
  status               ItemStatus @default(borrador)
  aiSummary            String?    @map("ai_summary")
  // New commercial fields for sales agents
  callToAction         String?    @map("call_to_action")
  idealStudentProfile  String?    @map("ideal_student_profile")
  competitiveAdvantage String?    @map("competitive_advantage")
  urgencyTriggers      String[]   @default([]) @map("urgency_triggers")
  objectionHandlers    Json       @default("[]") @map("objection_handlers") // [{objection, response}]
  successStories       Json       @default("[]") @map("success_stories") // [{name, role, quote, result}]

  // Relations
  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  attachments      Attachment[]
  faqs             Faq[]
  generatedContent GeneratedContent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("applications")
}

// ==============================
// TEAMS
// ==============================
model Team {
  id          String  @id @default(uuid())
  orgId       String  @map("org_id")
  name        String
  description String?

  org                Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members            TeamMember[]
  courses            Course[]
  programs           Program[]
  webinars           Webinar[]
  talleres           Taller[]
  asesorias          Asesoria[]
  agents             AiAgent[]
  productAssignments TeamProductAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("teams")
}

model TeamMember {
  id           String  @id @default(uuid())
  teamId       String  @map("team_id")
  name         String
  email        String
  phone        String?
  whatsapp     String?
  role         String? // e.g. "SDR", "Closer", "Account Executive"
  availability String? // e.g. "L-V 9am-6pm"

  // Vacation / Availability
  vacationStart DateTime? @map("vacation_start")
  vacationEnd   DateTime? @map("vacation_end")
  isAvailable   Boolean   @default(true) @map("is_available")

  // Sales capabilities
  specialties String[] @default([]) // Areas of expertise
  maxLeads    Int?     @map("max_leads") // Max simultaneous leads

  // Link to auth user (optional)
  userId String? @unique @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("team_members")
}

// Supports assigning any product type to a team (not just courses)
model TeamProductAssignment {
  id         String     @id @default(uuid())
  teamId     String     @map("team_id")
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, entityType, entityId])
  @@index([teamId])
  @@index([entityType, entityId])
  @@map("team_product_assignments")
}

// ==============================
// AI AGENTS
// ==============================
model AiAgent {
  id           String           @id @default(uuid())
  orgId        String           @map("org_id")
  name         String
  role         String           @default("")
  personality  AgentPersonality @default(professional)
  tone         String           @default("")
  language     String           @default("es")
  expertise    String[]         @default([])
  systemPrompt String?          @map("system_prompt")
  avatar       String?
  isActive     Boolean          @default(true) @map("is_active")

  // Sales context
  funnelId           String?  @map("funnel_id")
  extractionFieldIds String[] @default([]) @map("extraction_field_ids") // IDs of ExtractionFields this agent should extract

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  funnel       Funnel?       @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  teamId       String?       @map("team_id")
  team         Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  agentCourses AgentCourse[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("ai_agents")
}

model AgentCourse {
  id       String @id @default(uuid())
  agentId  String @map("agent_id")
  courseId String @map("course_id")

  agent  AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([agentId, courseId])
  @@map("agent_courses")
}

enum AgentPersonality {
  professional
  friendly
  empathetic
  strict
  enthusiastic
}

// ==============================
// SHARED: Attachments, FAQs
// ==============================
model Attachment {
  id             String     @id @default(uuid())
  entityType     EntityType @map("entity_type")
  courseId       String?    @map("course_id")
  programId      String?    @map("program_id")
  webinarId      String?    @map("webinar_id")
  tallerId       String?    @map("taller_id")
  subscriptionId String?    @map("subscription_id")
  asesoriaId     String?    @map("asesoria_id")
  applicationId  String?    @map("application_id")
  name           String
  url            String
  fileType       FileType   @default(pdf) @map("file_type")
  fileSize       String?    @map("file_size")

  course       Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  program      Program?      @relation(fields: [programId], references: [id], onDelete: Cascade)
  webinar      Webinar?      @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  taller       Taller?       @relation(fields: [tallerId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  asesoria     Asesoria?     @relation(fields: [asesoriaId], references: [id], onDelete: Cascade)
  application  Application?  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([courseId])
  @@index([programId])
  @@index([webinarId])
  @@index([tallerId])
  @@index([subscriptionId])
  @@index([asesoriaId])
  @@index([applicationId])
  @@map("attachments")
}

model Faq {
  id             String     @id @default(uuid())
  entityType     EntityType @map("entity_type")
  courseId       String?    @map("course_id")
  programId      String?    @map("program_id")
  webinarId      String?    @map("webinar_id")
  tallerId       String?    @map("taller_id")
  subscriptionId String?    @map("subscription_id")
  asesoriaId     String?    @map("asesoria_id")
  applicationId  String?    @map("application_id")
  question       String
  answer         String
  sortOrder      Int        @default(0) @map("sort_order")

  course       Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  program      Program?      @relation(fields: [programId], references: [id], onDelete: Cascade)
  webinar      Webinar?      @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  taller       Taller?       @relation(fields: [tallerId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  asesoria     Asesoria?     @relation(fields: [asesoriaId], references: [id], onDelete: Cascade)
  application  Application?  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([programId])
  @@index([webinarId])
  @@index([tallerId])
  @@index([subscriptionId])
  @@index([asesoriaId])
  @@index([applicationId])
  @@map("faqs")
}

enum EntityType {
  course
  program
  webinar
  taller
  subscription
  asesoria
  application
}

enum FileType {
  pdf
  video
  image
  link
}

// ==============================
// API KEYS (encrypted, per org)
// ==============================
model ApiKey {
  id           String     @id @default(uuid())
  orgId        String     @map("org_id")
  provider     AiProvider
  encryptedKey String     @map("encrypted_key")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([orgId, provider])
  @@map("api_keys")
}

enum AiProvider {
  gemini
  openai
}

// ==============================
// GENERATED CONTENT
// ==============================
model GeneratedContent {
  id             String     @id @default(uuid())
  orgId          String     @map("org_id")
  sourceType     EntityType @map("source_type")
  courseId       String?    @map("course_id")
  programId      String?    @map("program_id")
  webinarId      String?    @map("webinar_id")
  tallerId       String?    @map("taller_id")
  subscriptionId String?    @map("subscription_id")
  asesoriaId     String?    @map("asesoria_id")
  applicationId  String?    @map("application_id")
  toolId         String     @map("tool_id")
  content        String

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  course       Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  program      Program?      @relation(fields: [programId], references: [id], onDelete: Cascade)
  webinar      Webinar?      @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  taller       Taller?       @relation(fields: [tallerId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  asesoria     Asesoria?     @relation(fields: [asesoriaId], references: [id], onDelete: Cascade)
  application  Application?  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orgId])
  @@index([courseId])
  @@map("generated_content")
}

// ==============================
// SHARED ENUMS
