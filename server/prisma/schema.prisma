enum Modality {
  online
  presencial
  hibrido
}

enum ItemStatus {
  borrador
  activo
  archivado
}

// ==============================
// CONTACTS (GHL Integration)
// ==============================
model Contact {
  id    String @id @default(uuid())
  orgId String @map("org_id")

  // Identification
  ghlContactId String? @unique @map("ghl_contact_id")
  name         String
  email        String?
  phone        String?
  phoneCountry String? @map("phone_country")

  // CRM / Pipeline
  stage        ContactStage  @default(nuevo)
  origin       ContactOrigin @default(organico)
  customOrigin String?       @map("custom_origin")

  // Interest
  courseInterest       String?  @map("course_interest")
  programInterest      String?  @map("program_interest")
  webinarInterest      String?  @map("webinar_interest")
  tallerInterest       String?  @map("taller_interest")
  subscriptionInterest String?  @map("subscription_interest")
  asesoriaInterest     String?  @map("asesoria_interest")
  applicationInterest  String?  @map("application_interest")
  budget               Decimal? @default(0)
  currency             String   @default("USD")

  // Location
  city     String?
  country  String?
  timezone String?

  // Marketing / Tracking
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  adPlatform  String? @map("ad_platform")
  landingPage String? @map("landing_page")

  // Status
  isActive        Boolean   @default(true) @map("is_active")
  lastContactedAt DateTime? @map("last_contacted_at")
  nextFollowUpAt  DateTime? @map("next_follow_up_at")

  // Assignment
  assignedTo String? @map("assigned_to")

  // Notes
  notes String?
  tags  String[] @default([])

  // GHL Sync
  ghlLastSyncAt DateTime? @map("ghl_last_sync_at")
  ghlData       Json?     @map("ghl_data")

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([orgId, stage])
  @@index([ghlContactId])
  @@index([phone])
  @@map("contacts")
}

enum ContactStage {
  nuevo
  contactado
  interesado
  propuesta
  negociacion
  ganado
  perdido
  inactivo
}

// ==============================
// CRM CONFIGURATION
// ==============================
model Funnel {
  id          String  @id @default(uuid())
  orgId       String  @map("org_id")
  name        String
  description String?
  isDefault   Boolean @default(false) @map("is_default")

  org    Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stages FunnelStage[]
  fields ExtractionField[]
  agents AiAgent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("crm_funnels")
}

model FunnelStage {
  id          String  @id @default(uuid())
  funnelId    String  @map("funnel_id")
  name        String
  key         String?
  description String?
  rules       String?
  isDefault   Boolean @default(false) @map("is_default")
  sortOrder   Int     @default(0) @map("sort_order")
  color       String?

  funnel Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@index([funnelId])
  @@map("crm_funnel_stages")
}

model ExtractionField {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  funnelId    String?  @map("funnel_id")
  name        String
  key         String
  description String?
  dataType    String   @default("string")
  isRequired  Boolean  @default(false) @map("is_required")
  isDefault   Boolean  @default(false) @map("is_default")
  options     String[] @default([]) // For dropdowns/selects

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  funnel Funnel?      @relation(fields: [funnelId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@map("crm_extraction_fields")
}

// ==============================
// FILTER QUESTIONS (Preguntas de calificación para prospectos)
// ==============================
model FilterQuestion {
  id          String  @id @default(uuid())
  orgId       String  @map("org_id")
  courseId     String? @map("course_id")
  question    String
  fieldKey    String  @map("field_key")
  type        String  @default("text") // text | select | multiselect | radio | yesno
  options     String[] @default([])
  isRequired  Boolean @default(false) @map("is_required")
  isActive    Boolean @default(true) @map("is_active")
  productType String  @default("all") @map("product_type") // all | curso | webinar | programa | taller | asesoria | postulacion | subscripcion
  sortOrder   Int     @default(0) @map("sort_order")
  placeholder String?

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  course Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([courseId])
  @@map("filter_questions")
}

enum ContactOrigin {
  organico
  meta_ads
  google_ads
  tiktok_ads
  referido
  webinar
  evento
  linkedin
  whatsapp
  email
  agente_lia
  otro
}

// ==============================
// GHL CONNECTION (OAuth2 Integration)
// ==============================
model GhlConnection {
  id    String @id @default(uuid())
  orgId String @unique @map("org_id")

  // OAuth tokens
  accessToken  String  @map("access_token")
  refreshToken String  @map("refresh_token")
  tokenType    String  @default("Bearer") @map("token_type")
  expiresAt    DateTime @map("expires_at")

  // GHL account info
  locationId String? @map("location_id")
  companyId  String? @map("company_id")
  userId     String? @map("user_id")
  userType   String  @default("Location") @map("user_type") // Company | Location

  // Private Integration API Key (for setup operations)
  privateApiKey String? @map("private_api_key")

  // Sync metadata
  lastSyncAt    DateTime? @map("last_sync_at")
  contactsSynced Int      @default(0) @map("contacts_synced")
  isActive       Boolean  @default(true) @map("is_active")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ghl_connections")
}
